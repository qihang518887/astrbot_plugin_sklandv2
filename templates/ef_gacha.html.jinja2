{% from "ef_gacha_macros.html.jinja2" import ef_pool_column, ef_pool_card %}

<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <title>Endfield Gacha History</title>
    <style>
        {% include "index.css" %}
    </style>
</head>

<body>
    <div class="relative w-auto h-auto flex flex-col p-4 gap-4 bg-[#1a1a2e]" style="min-width: 680px;">

        {# ═══════════════════ 上半部分：账号信息 + 统计数据 ═══════════════════ #}

        {# 账号信息横条 #}
        <div class="flex items-center bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow">
            <div class="flex items-center gap-2 flex-1">
                <div class="w-10 h-10 bg-[#3a3a4e] rounded-lg flex items-center justify-center flex-shrink-0">
                    <img src="{{ avatar_url }}" alt="avatar" class="w-full h-full rounded-lg">
                </div>
                <div>
                    <h1 class="text-sm text-white font-bold font-[Akrobat]">{{ character.nickname }}</h1>
                    <span class="text-white/50 text-[10px] font-[Bender]">UID: {{ character.role_id }}</span>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-baseline gap-1">
                    <span class="text-white font-[Akrobat] font-bold text-2xl">{{ record.total_pulls }}</span>
                    <span class="text-white/60 text-xs font-[Akrobat]">抽</span>
                </div>
                <div class="h-6 w-px bg-white/10"></div>
                <div class="flex gap-3">
                    <div class="flex flex-col items-center">
                        <span class="text-[#6C5CE7] font-[Akrobat] font-bold text-sm">{{ record.char_total_pulls }}</span>
                        <span class="text-white/40 text-[9px]">角色池</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-[#e17055] font-[Akrobat] font-bold text-sm">{{ record.weapon_total_pulls }}</span>
                        <span class="text-white/40 text-[9px]">武器池</span>
                    </div>
                </div>
            </div>
        </div>

        {# 统计卡片 - 均等宽度 #}
        <div class="flex flex-row gap-2">
                {# 限定池统计 #}
                <div class="flex-1 bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow flex flex-col justify-between">
                    <div class="flex items-center gap-1.5 mb-1">
                        <div class="w-1 h-4 rounded-full bg-[#e17055]"></div>
                        <span class="text-white font-[Akrobat] font-bold text-sm">限定池</span>
                    </div>
                    <div class="text-center mb-1">
                        <span class="text-white font-[Akrobat] font-bold text-2xl">{{ record.special_total_pulls }}</span>
                        <span class="text-white/60 text-sm font-[Akrobat]">抽</span>
                    </div>
                    <div class="flex justify-around text-center gap-1">
                        <div class="flex flex-col">
                            <span class="font-[Akrobat] font-bold text-base">
                                <span class="text-[#FFCC00]">{{ record.special_total_six }}</span><span class="text-white/40">/</span><span class="text-[#C04855]">{{ record.special_total_spook }}</span>
                            </span>
                            <span class="text-white/40 text-[10px]">6★/歪</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-[Akrobat] font-bold text-base">{{ "%.1f"|format(record.special_up_avg) if record.special_up_count > 0 else "-" }}</span>
                            <span class="text-white/40 text-[10px]">UP平均</span>
                        </div>
                    </div>
                    {# 限定池跨池小保底进度条 #}
                    <div class="mt-1.5">
                        <div class="flex justify-between text-[10px] text-white/40 mb-0.5">
                            <span>小保底</span>
                            <span>{{ record.special_pity }}/80</span>
                        </div>
                        <div class="w-full h-2 bg-[#1a1a2e] rounded-full overflow-hidden">
                            <div class="h-full rounded-full green-blur-bar" style="width: {{ (record.special_pity / 80 * 100) | int }}%;"></div>
                        </div>
                    </div>

                </div>

                {# 武器池统计 #}
                <div class="flex-1 bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow flex flex-col justify-between">
                    <div class="flex items-center gap-1.5 mb-1">
                        <div class="w-1 h-4 rounded-full bg-[#fdcb6e]"></div>
                        <span class="text-white font-[Akrobat] font-bold text-sm">武器池</span>
                    </div>
                    <div class="text-center mb-1">
                        <span class="text-white font-[Akrobat] font-bold text-2xl">{{ record.weapon_total_pulls }}</span>
                        <span class="text-white/60 text-sm font-[Akrobat]">抽</span>
                    </div>
                    <div class="flex justify-around text-center gap-1">
                        <div class="flex flex-col">
                            <span class="font-[Akrobat] font-bold text-base">
                                <span class="text-[#FFCC00]">{{ record.weapon_total_six }}</span><span class="text-white/40">/</span><span class="text-[#C04855]">{{ record.weapon_total_spook }}</span>
                            </span>
                            <span class="text-white/40 text-[10px]">6★/歪</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-[Akrobat] font-bold text-base">{{ "%.1f"|format(record.weapon_up_avg) if record.weapon_up_count > 0 else "-" }}</span>
                            <span class="text-white/40 text-[10px]">UP平均</span>
                        </div>
                    </div>
                    {# 武器池保底进度条 #}
                    <div class="mt-1.5">
                        <div class="flex justify-between text-[10px] text-white/40 mb-0.5">
                            <span>保底</span>
                            <span>{{ record.weapon_pity }}/80</span>
                        </div>
                        <div class="w-full h-2 bg-[#1a1a2e] rounded-full overflow-hidden">
                            <div class="h-full rounded-full green-blur-bar" style="width: {{ (record.weapon_pity / 80 * 100) | int }}%;"></div>
                        </div>
                    </div>
                </div>

                {# 常驻池统计 #}
                <div class="flex-1 bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow flex flex-col justify-between">
                    <div class="flex items-center gap-1.5 mb-1">
                        <div class="w-1 h-4 rounded-full bg-[#00b894]"></div>
                        <span class="text-white font-[Akrobat] font-bold text-sm">常驻池</span>
                    </div>
                    <div class="text-center mb-1">
                        <span class="text-white font-[Akrobat] font-bold text-2xl">{{ record.standard_total_pulls }}</span>
                        <span class="text-white/60 text-sm font-[Akrobat]">抽</span>
                    </div>
                    <div class="flex justify-around text-center gap-1">
                        <div class="flex flex-col">
                            <span class="text-[#FFCC00] font-[Akrobat] font-bold text-base">{{ record.standard_total_six }}</span>
                            <span class="text-white/40 text-[10px]">6★</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-[Akrobat] font-bold text-base">{{ "%.1f"|format(record.standard_six_avg) if record.standard_total_six > 0 else "-" }}</span>
                            <span class="text-white/40 text-[10px]">6★平均</span>
                        </div>
                    </div>
                    {# 常驻池保底进度条 #}
                    <div class="mt-1.5">
                        <div class="flex justify-between text-[10px] text-white/40 mb-0.5">
                            <span>保底</span>
                            <span>{{ record.standard_pity }}/80</span>
                        </div>
                        <div class="w-full h-2 bg-[#1a1a2e] rounded-full overflow-hidden">
                            <div class="h-full rounded-full green-blur-bar" style="width: {{ (record.standard_pity / 80 * 100) | int }}%;"></div>
                        </div>
                    </div>
                </div>

                {# 新手池统计 #}
                {% if record.beginner_pools %}
                <div class="flex-1 bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow flex flex-col justify-between">
                    <div class="flex items-center gap-1.5 mb-1">
                        <div class="w-1 h-4 rounded-full bg-[#74b9ff]"></div>
                        <span class="text-white font-[Akrobat] font-bold text-sm">新手池</span>
                    </div>
                    <div class="text-center mb-1">
                        <span class="text-white font-[Akrobat] font-bold text-2xl">{{ record.beginner_total_pulls }}</span>
                        <span class="text-white/60 text-sm font-[Akrobat]">抽</span>
                    </div>
                    <div class="flex justify-around text-center gap-1">
                        <div class="flex flex-col">
                            <span class="text-[#FFCC00] font-[Akrobat] font-bold text-base">{{ record.beginner_pools | sum(attribute='total_six_stars') }}</span>
                            <span class="text-white/40 text-[10px]">6★</span>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-white font-[Akrobat] font-bold text-base">{{ record.beginner_total_pulls }}/40</span>
                            <span class="text-white/40 text-[10px]">进度</span>
                        </div>
                    </div>
                </div>
                {% endif %}

            {# 武库配额 #}
            <div class="flex-1 bg-[#2a2a3e] rounded-xl p-3 gacha-info-shadow flex flex-col">
                <div class="flex items-center gap-1.5 mb-1.5">
                    <div class="w-1 h-4 rounded-full bg-[#a29bfe]"></div>
                    <span class="text-white font-[Akrobat] font-bold text-sm">武库配额</span>
                </div>
                <div class="flex flex-col gap-1.5 flex-1 justify-center">
                    <div class="flex justify-around text-center">
                        <div class="flex flex-col items-center">
                            <span class="text-white/50 text-[9px]">产出</span>
                            <span class="text-[#00b894] font-[Akrobat] font-bold text-base">{{ record.char_arsenal_quota_earned }}</span>
                        </div>
                        <div class="flex flex-col items-center">
                            <span class="text-white/50 text-[9px]">消耗</span>
                            <span class="text-[#e17055] font-[Akrobat] font-bold text-base">{{ record.weapon_arsenal_quota_consumed }}</span>
                        </div>
                    </div>
                    <div class="flex justify-center">
                        <div class="h-px w-3/4 bg-[#3a3a4e] rounded-full"></div>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-white/50 text-[9px]">净值</span>
                        <span class="font-[Akrobat] font-bold text-xl {% if record.arsenal_quota_net >= 0 %}text-[#00b894]{% else %}text-[#e17055]{% endif %}">
                            {{ record.arsenal_quota_net }}
                        </span>
                    </div>
                </div>
            </div>
        </div>

        {# ═══════════════════ 下半部分：卡池详情 从左到右 ═══════════════════ #}
        {# 计算可见卡池ID集合（基于 start_index/end_index 对 flat_pools 切片） #}
        {% if start_index is not none or end_index is not none %}
        {% set visible_ids = record.get_visible_pool_ids(start_index, end_index) %}
        {% else %}
        {% set visible_ids = none %}
        {% endif %}

        <div class="flex flex-row gap-3 items-start">
            {{ ef_pool_column(record.special_pools, "限定池", "#e17055", gacha_data=record, visible_pool_ids=visible_ids) }}
            {{ ef_pool_column(record.weapon_pools, "武器池", "#fdcb6e", gacha_data=record, visible_pool_ids=visible_ids) }}

            {# 新手池 + 常驻池合并列 #}
            {% if visible_ids is not none %}
            {% set vis_beginner = record.beginner_pools | selectattr('pool_id', 'in', visible_ids) | list %}
            {% set vis_standard = record.standard_pools | selectattr('pool_id', 'in', visible_ids) | list %}
            {% else %}
            {% set vis_beginner = record.beginner_pools %}
            {% set vis_standard = record.standard_pools %}
            {% endif %}

            {% if vis_standard or vis_beginner %}
            <div class="flex flex-col gap-2 flex-1">
                {% if vis_beginner %}
                <div class="flex items-center gap-1.5">
                    <div class="w-1 h-3.5 rounded-full" style="background-color: #74b9ff"></div>
                    <span class="text-white font-[Akrobat] font-bold text-sm">新手池</span>
                    <span class="text-white/40 font-[Akrobat] text-[10px]">({{ vis_beginner | sum(attribute='total_pulls') }}抽)</span>
                </div>
                {% for pool in vis_beginner %}
                {{ ef_pool_card(pool, "新手池", "#74b9ff", gacha_data=record) }}
                {% endfor %}
                {% endif %}

                {% if vis_standard %}
                <div class="flex items-center gap-1.5">
                    <div class="w-1 h-3.5 rounded-full" style="background-color: #00b894"></div>
                    <span class="text-white font-[Akrobat] font-bold text-sm">常驻池</span>
                    <span class="text-white/40 font-[Akrobat] text-[10px]">({{ vis_standard | sum(attribute='total_pulls') }}抽)</span>
                </div>
                {% for pool in vis_standard %}
                {{ ef_pool_card(pool, "常驻池", "#00b894", gacha_data=record) }}
                {% endfor %}
                {% endif %}
            </div>
            {% endif %}
        </div>

        <footer class="text-center text-white/40 text-xs font-[Bender] pt-2">Generated by nonebot-plugin-skland</footer>
    </div>
</body>

</html>
